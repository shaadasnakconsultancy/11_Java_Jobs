public void appendHtmlToTxtFile(String filePath, String htmlContent,String logMessages) {

    FileWriter fw = null;
    BufferedWriter bw = null;

    try {
        File file = new File(filePath);

        // ✅ Step 1: Create directory if not exists
        File parentDir = file.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            parentDir.mkdirs();
        }

        // ✅ Step 2: Create file if not exists
        if (!file.exists()) {
            file.createNewFile();
        }

        // ✅ Step 3: Append content
        fw = new FileWriter(file, true); // true = append mode
        bw = new BufferedWriter(fw);

        bw.write("================start=====================");
        bw.newLine();
        bw.write("Execution Time: " + new java.util.Date());
        bw.newLine();
        bw.write(htmlContent);
        bw.newLine();
        bw.newLine();
        if(logMessages!=null) { bw.write(logMessages);}
        bw.newLine();
        bw.write("=================end====================");
        bw.newLine();
        bw.newLine();

    } catch (Exception e) {
        e.printStackTrace();
    } finally {
        try {
            if (bw != null) bw.close();
            if (fw != null) fw.close();
        } catch (Exception ex) {
            ex.printStackTrace();
        }
    }
}





