        public static void moveToArchive(List<File> allFiles) {
        	Path targetPath=null;
        	Path filePath =null;
        	for (File file : allFiles) {
        	
        	
            try {
                  filePath = file.toPath();

                // ================= STEP 1 =================
                // Get parent folder (e.g., Budget)
                // Example:
                // C:\Jobs\FY27-28\P&L\Budget\file1.xlsx
                // → parent = C:\Jobs\FY27-28\P&L\Budget

                Path parentDir = filePath.getParent();

                // ================= STEP 2 =================
                // Create Archive folder path
                // → C:\Jobs\FY27-28\P&L\Budget\Archive

                Path archiveDir = parentDir.resolve("Archive");

                // ================= STEP 3 =================
                // Create Archive folder if not exists

                if (!Files.exists(archiveDir)) {
                    Files.createDirectories(archiveDir);
                }

                // ================= STEP 4 =================
                // Target file path in Archive
                // Timestamp
                String timeStamp = new SimpleDateFormat("yyyy-MM-dd_HH_mm_ss")
                        .format(new Date());
                  targetPath = archiveDir.resolve(timeStamp+"_"+filePath.getFileName() );

                // ================= STEP 5 =================
                // Move file

                Files.move(
                        filePath,
                        targetPath,
                        StandardCopyOption.REPLACE_EXISTING // overwrite if exists
                );

                System.out.println("Moved: " + file.getName());

            } catch (IOException e) {
                e.printStackTrace();
            	GlobalExceptionHandler_AND_EmailSender.handleException(   new PrintLog_AND_SendEmail_Exception(  new newFiletSoFYFolderIsTheirAsParentInJobFolder().getClass().getName(), 
                       
                        "moveToArchive() method, ",
                        file.getName(),
                        " <- Problem occurred while archiving this file",
                        "Moving from [" + filePath + "] to [" + targetPath + "]"
                        
                ));
            }
        }
    
