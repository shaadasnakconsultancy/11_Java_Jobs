            // Remove FY folder (first element)
            // Example:
            // ["FY23-24", "P&L", "Budget"]
            // → remove index 0
            // → remaining = P&L\Budget

            StringBuilder subPathBuilder = new StringBuilder();

            for (int i = 1; i < parts.length; i++) {
                subPathBuilder.append(parts[i]);

                if (i < parts.length - 1) {
                    subPathBuilder.append("\\");
                }
            }

            String subPathStr = subPathBuilder.toString();

            // Convert to Path
            Path subPath = Paths.get(subPathStr);

            // ================= STEP 4 =================
            // Loop all FY folders inside baseDir

            try (DirectoryStream<Path> fyFolders = Files.newDirectoryStream(Paths.get(baseDir))) {
            	abc:
                for (Path fyFolder : fyFolders) {

                    if (Files.isDirectory(fyFolder)) {

